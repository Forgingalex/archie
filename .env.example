# Server
PORT=3000                          # Port the Fastify server listens on
NODE_ENV=development               # Set to "production" in deployed environments
ARCHIE_API_KEY=                    # Optional: set to require "Authorization: Bearer <key>" on /agent and /ask routes

# LLM Planner
GROQ_API_KEY=                      # Groq API key for Llama 3 — free at https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile # Override the default Groq model if needed

# Arc Testnet
ARC_RPC_URL=https://rpc.testnet.arc.network  # Arc Testnet RPC endpoint
ARC_CHAIN_ID=5042002               # Arc Testnet chain ID

# Circle Developer-Controlled Wallets (required for x402 payments and Arc identity)
# Create a project at https://console.circle.com and copy the API key + entity secret
CIRCLE_API_KEY=                    # Circle API key
CIRCLE_ENTITY_SECRET=              # Circle entity secret (used to sign wallet operations)

# Arc wallet IDs — set these after running: npm run register-agent
# The script creates the wallets and prints the IDs to copy here
ARC_AGENT_WALLET_ID=               # Circle wallet ID for the agent (handles x402 payments)
ARC_VALIDATOR_WALLET_ID=           # Circle wallet ID for the validator (signs ERC-8004 reputation events)
ARC_AGENT_ID=                      # Onchain agent ID from IdentityRegistry (printed by register-agent.ts)

# Connector API keys
COINGECKO_API_KEY=                 # CoinGecko API key — free tier works without one; get at https://www.coingecko.com/en/api
TWITTER_BEARER_TOKEN=              # Twitter/X Bearer Token — from https://developer.x.com (Basic plan or higher)
NEWS_API_KEY=                      # NewsAPI key — free tier at https://newsapi.org
ETHERSCAN_API_KEY=                 # Etherscan API key — free at https://etherscan.io/apis
EXCHANGE_RATE_API_KEY=             # ExchangeRate-API key — free tier at https://www.exchangerate-api.com (unused by current open.er-api endpoint)

# x402 EOA Payment Wallet (autonomous USDC micropayments on Base Sepolia)
# Generate a new wallet: npx tsx scripts/generate-wallet.ts
# Fund with testnet USDC at https://faucet.circle.com (select Base Sepolia network)
X402_PRIVATE_KEY=                  # 0x-prefixed private key for the EOA payment wallet
X402_NETWORK=base-sepolia          # x402 payment network (base-sepolia for testnet)

# GoldRush x402 API — premium blockchain data (token balances, NFTs, transactions) via x402
GOLDRUSH_X402_URL=https://x402.goldrush.dev  # GoldRush x402 base URL
